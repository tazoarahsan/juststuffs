  },
  leads:{
    label:'Not enough leads to need a CRM',
    first:{
      primary:{ic:'pause', title:'Pause your plan — $49/mo', desc:'Keep your numbers active and data safe. Resume the moment deals pick back up.', outcome:'pause'},
      secondary:{ic:'down', title:'Move from Pro to Basic — $199/mo', desc:'A lighter plan for the slow stretch — keep your data and numbers.', outcome:'basic'}
    },
    final:{
      primary:{ic:'percent', title:'50% off for your next 6 months', desc:'Stay fully active at half the cost while you build pipeline. Reverts after 6 cycles.', outcome:'disc6'},
      secondary:{ic:'pause', title:'Pause your plan — $49/mo', desc:'Keep your numbers active and data safe. Resume anytime.', outcome:'pause'}
