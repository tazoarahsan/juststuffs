  zap:'<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>'
};
const icon = (n)=>`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${ICONS[n]||''}</svg>`;

/* ============================================================
   OFFER MATRIX  →  reason drives primary + final offers
   (mirrors the retention plan's matrix exactly)
   ============================================================ */
const REASONS = {
  expensive:{
    label:'Too expensive',
    // Pro user citing price: lead with discount, downgrade as the alternate (matches mockup screen 3)
    first:{
