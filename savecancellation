
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>REsimpli — Billing & Cancellation Flow</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ============================================================
   REsimpli — Billing page + Cancellation Save Flow (prototype)
   Brand: #008088 dark teal · display feel: Gilroy (Plus Jakarta Sans web stand-in)
   Flow logic mirrors the retention "Offer Matrix" exactly (see REASONS in JS).
   ============================================================ */

:root{
  --teal:#008088;
  --teal-dark:#006970;
  --teal-700:#0a6e74;
  --teal-tint:#e7f4f3;
  --teal-tint-2:#d6ecea;
  --teal-border:#a9d6d3;

  --navy:#1e2a37;
  --navy-2:#172230;

  --red:#dc2f3a;
  --red-soft:#fdeaea;
  --red-700:#b91c1c;

  --ink:#101828;
  --ink-2:#475467;
  --ink-3:#667085;
  --line:#e7eaee;
  --line-2:#eef1f4;
  --bg:#f6f7f9;
  --card:#ffffff;
  --amber:#b54708;
  --amber-soft:#fef6ee;

  --shadow-sm:0 1px 2px rgba(16,24,40,.06);
  --shadow-md:0 8px 24px rgba(16,24,40,.10);
  --shadow-lg:0 24px 60px rgba(16,24,40,.22);
  --radius:14px;
  --rail:72px;
  --topbar:64px;
  --font:'Plus Jakarta Sans','Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
}

*{box-sizing:border-box}
html,body{margin:0;padding:0}
body{
  font-family:var(--font);
  color:var(--ink);
  background:var(--bg);
  -webkit-font-smoothing:antialiased;
  text-rendering:optimizeLegibility;
}
button{font-family:inherit}
svg{width:1em;height:1em;display:block}

/* ---------------------------------- App shell ---------------------------------- */
.app{display:flex;min-height:100vh}

/* Rail (slim dark icon sidebar, matches live app) */
.rail{
  width:var(--rail);
  background:var(--navy);
  color:#9fb0c0;
  display:flex;flex-direction:column;align-items:center;
  padding:14px 0 12px;gap:6px;
  position:sticky;top:0;height:100vh;flex:0 0 var(--rail);
}
.rail__logo{
  width:42px;height:42px;border-radius:12px;
  background:linear-gradient(160deg,var(--teal),#03686f);
  display:grid;place-items:center;color:#fff;font-size:22px;margin-bottom:10px;
  box-shadow:0 6px 14px rgba(0,128,136,.4);
}
.rail__btn{
  width:42px;height:42px;border-radius:11px;border:0;background:transparent;color:#92a3b4;
  display:grid;place-items:center;font-size:20px;cursor:pointer;transition:.15s;position:relative;
}
.rail__btn:hover{background:rgba(255,255,255,.07);color:#dfe7ee}
.rail__btn.is-active{background:rgba(0,128,136,.22);color:#5fd0c9}
.rail__btn.is-active::before{content:"";position:absolute;left:-14px;top:9px;bottom:9px;width:3px;border-radius:0 3px 3px 0;background:var(--teal)}
.rail__spacer{flex:1}
.rail__btn .dot{position:absolute;top:7px;right:7px;width:7px;height:7px;border-radius:50%;background:var(--red);border:1.5px solid var(--navy)}

/* Main column */
.main{flex:1;min-width:0;display:flex;flex-direction:column}

/* Topbar */
.topbar{
  height:var(--topbar);background:#fff;border-bottom:1px solid var(--line);
  display:flex;align-items:center;gap:18px;padding:0 20px;position:sticky;top:0;z-index:20;
}
.onb{display:flex;align-items:center;gap:9px;flex:0 0 auto;text-decoration:none}
.ring{width:34px;height:34px}
.onb__txt{color:var(--red);font-weight:700;font-size:13.5px;white-space:nowrap}
.search{
  flex:1 1 280px;max-width:420px;min-width:120px;display:flex;align-items:center;gap:9px;
  background:#f3f4f6;border:1px solid #eceef1;border-radius:10px;padding:8px 12px;color:var(--ink-3);
}
.search input{border:0;background:transparent;outline:none;font-size:14px;color:var(--ink);width:100%}
.search input::placeholder{color:#98a2b3}
.topbar__links{display:flex;align-items:center;gap:20px;flex:0 0 auto}
.tlink{color:var(--red);font-weight:700;font-size:13.5px;text-decoration:underline;white-space:nowrap;cursor:pointer}
.tlink--count{text-decoration:underline}
.topbar__right{margin-left:auto;display:flex;align-items:center;gap:12px;flex:0 0 auto}
.btn-add{display:flex;align-items:stretch;border-radius:9px;overflow:hidden;box-shadow:var(--shadow-sm)}
.btn-add__main{background:var(--teal);color:#fff;border:0;font-weight:700;font-size:14px;padding:9px 14px;display:flex;align-items:center;gap:7px;cursor:pointer}
.btn-add__main:hover{background:var(--teal-dark)}
.btn-add__caret{background:var(--teal-dark);color:#fff;border:0;width:30px;display:grid;place-items:center;cursor:pointer;font-size:12px}
.iconbtn{width:38px;height:38px;border-radius:9px;border:1px solid var(--line);background:#fff;color:var(--ink-2);display:grid;place-items:center;font-size:17px;cursor:pointer;position:relative}
.iconbtn:hover{background:#f6f7f9}
.iconbtn .dot{position:absolute;top:7px;right:8px;width:7px;height:7px;border-radius:50%;background:var(--red)}
.balance{display:flex;align-items:center;gap:8px;border:1px solid var(--line);border-radius:9px;padding:7px 12px;background:#fff;cursor:pointer;font-weight:700;font-size:13.5px;color:var(--ink)}
.balance .coin{width:20px;height:20px;border-radius:50%;background:#eef1f4;display:grid;place-items:center;font-size:11px;color:var(--ink-2)}
.avatar{display:flex;align-items:center;gap:6px;border:1px solid var(--line);border-radius:30px;padding:4px 8px 4px 4px;cursor:pointer;background:#fff}
.avatar img,.avatar .ph{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#0a6e74,#0fb5a8);display:grid;place-items:center;color:#fff;font-weight:700;font-size:13px}

/* Content */
.content{padding:26px 30px 60px;max-width:1180px;width:100%}
.page-title{font-size:24px;font-weight:800;letter-spacing:-.01em;margin:2px 0 18px}

.card-block{background:var(--card);border:1px solid var(--line);border-radius:16px;box-shadow:var(--shadow-sm);margin-bottom:20px}
.card-block__head{display:flex;align-items:center;justify-content:space-between;gap:14px;padding:18px 22px;border-bottom:1px solid var(--line-2);flex-wrap:wrap}
.card-block__title{font-size:16px;font-weight:800;display:flex;align-items:center;gap:8px}
.card-block__title .muted{color:var(--ink-3);font-weight:700}
.card-block__body{padding:6px 22px 20px}
.head-actions{display:flex;align-items:center;gap:12px;flex-wrap:wrap}

.btn-outline{border:1.5px solid;border-radius:9px;padding:9px 15px;font-weight:700;font-size:14px;background:#fff;cursor:pointer;display:inline-flex;align-items:center;gap:8px;transition:.15s}
.btn-outline--danger{color:var(--red);border-color:#f3c1c4}
.btn-outline--danger:hover{background:var(--red-soft)}
.btn-outline--danger:disabled{opacity:.45;cursor:not-allowed}
.btn-outline--neutral{color:var(--teal);border-color:var(--teal-border)}
.btn-outline--neutral:hover{background:var(--teal-tint)}

/* Current plan */
.plan{display:flex;align-items:flex-start;justify-content:space-between;gap:20px;padding:20px 22px;flex-wrap:wrap}
.plan__left{min-width:240px}
.plan__name{font-size:20px;font-weight:800;display:flex;align-items:center;gap:10px}
.pill{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:700;padding:3px 10px;border-radius:30px;line-height:1.5}
.pill--ok{background:var(--teal-tint);color:var(--teal-700)}
.pill--warn{background:var(--amber-soft);color:var(--amber)}
.pill--bad{background:var(--red-soft);color:var(--red-700)}
.plan__price{margin-top:7px;color:var(--ink-2);font-size:14.5px;font-weight:600}
.plan__price s{color:var(--ink-3);font-weight:500;margin-right:6px}
.plan__note{margin-top:10px}
.plan__feats{display:flex;flex-wrap:wrap;gap:8px 16px;margin-top:16px}
.feat{display:flex;align-items:center;gap:7px;color:var(--ink-2);font-size:13.5px;font-weight:600}
.feat svg{color:var(--teal);width:16px;height:16px}
.plan__right{display:flex;gap:10px;align-items:center;flex-wrap:wrap}

/* Cards table */
.table{width:100%;border-collapse:collapse}
.table th{text-align:left;font-size:13.5px;color:var(--ink-2);font-weight:700;padding:14px 8px;border-bottom:1px solid var(--line-2)}
.table td{padding:18px 8px;border-bottom:1px solid var(--line-2);font-size:14.5px;vertical-align:middle}
.table tr:last-child td{border-bottom:0}
.cardcell{display:flex;align-items:center;gap:12px;font-weight:600}
.brandmark{width:34px;height:22px;border-radius:4px;background:#1a1f71;color:#fff;font-size:10px;font-weight:800;display:grid;place-items:center;letter-spacing:.5px}
.act{display:flex;align-items:center;gap:18px;color:var(--ink-3)}
.act__icon{background:none;border:0;cursor:pointer;color:var(--ink-3);font-size:17px;display:grid;place-items:center}
.act__icon:hover{color:var(--ink)}
.radio-prim{display:flex;align-items:center;gap:9px;cursor:pointer;font-weight:700;color:var(--ink)}
.radio-prim .ring-r{width:18px;height:18px;border-radius:50%;border:2px solid var(--teal);display:grid;place-items:center}
.radio-prim .ring-r i{width:9px;height:9px;border-radius:50%;background:var(--teal);display:block}

/* invoices */
.inv-row{display:flex;align-items:center;justify-content:space-between;padding:14px 8px;border-bottom:1px solid var(--line-2);font-size:14px}
.inv-row:last-child{border-bottom:0}
.inv-row .left{display:flex;align-items:center;gap:14px}
.inv-row .date{color:var(--ink-2);font-weight:600;min-width:110px}
.inv-row .amt{font-weight:700}
.inv-paid{font-size:12px;font-weight:700;color:var(--teal-700);background:var(--teal-tint);padding:2px 9px;border-radius:20px}
.inv-link{color:var(--teal);font-weight:700;text-decoration:none;font-size:13.5px;cursor:pointer}
.inv-link:hover{text-decoration:underline}

.hint{color:var(--ink-3);font-size:13px;margin:-4px 8px 0}

/* ---------------------------------- Modal / Flow ---------------------------------- */
.overlay{
  position:fixed;inset:0;background:rgba(16,24,40,.55);backdrop-filter:blur(2px);
  display:flex;align-items:center;justify-content:center;padding:24px;z-index:100;
  opacity:0;visibility:hidden;transition:opacity .2s ease;
}
.overlay.is-open{opacity:1;visibility:visible}
.modal{
  width:100%;max-width:520px;background:#fff;border-radius:22px;box-shadow:var(--shadow-lg);
  padding:34px 34px 30px;transform:translateY(10px) scale(.98);opacity:0;transition:transform .22s ease,opacity .22s ease;
  max-height:92vh;overflow:auto;
}
.overlay.is-open .modal{transform:translateY(0) scale(1);opacity:1}

/* progress dots */
.steps{display:flex;align-items:center;justify-content:center;gap:0;margin:2px 0 22px}
.steps .node{width:30px;height:30px;border-radius:50%;display:grid;place-items:center;font-weight:800;font-size:13px;flex:0 0 auto}
.node--done{background:var(--teal);color:#fff}
.node--active{background:var(--teal);color:#fff;box-shadow:0 0 0 4px var(--teal-tint)}
.node--todo{background:#eef1f4;color:#98a2b3}
.steps .bar{height:2px;width:52px;background:#e7eaee}
.steps .bar--done{background:var(--teal)}

.glyph{width:62px;height:62px;border-radius:50%;display:grid;place-items:center;margin:0 auto 16px;font-size:26px}
.glyph--warn{background:var(--red-soft);color:var(--red)}
.glyph--x{background:var(--red-soft);color:var(--red)}
.glyph--ok{background:var(--teal-tint);color:var(--teal)}

.m-title{font-size:23px;font-weight:800;text-align:center;letter-spacing:-.01em;margin:0 0 8px}
.m-sub{text-align:center;color:var(--ink-2);font-size:14.5px;line-height:1.5;margin:0 auto 22px;max-width:400px}

/* effects list */
.effects{display:flex;flex-direction:column;gap:14px;margin:6px 0 26px}
.effect{display:flex;align-items:center;gap:14px}
.effect__ic{width:40px;height:40px;border-radius:10px;background:var(--red-soft);color:var(--red);display:grid;place-items:center;font-size:18px;flex:0 0 auto}
.effect__tx{color:var(--ink);font-size:14.5px;font-weight:600}

/* reason options */
.reasons{display:flex;flex-direction:column;gap:11px;margin-bottom:22px}
.reason{
  display:flex;align-items:center;gap:12px;width:100%;text-align:left;cursor:pointer;
  border:1.6px solid var(--line);background:#fff;border-radius:12px;padding:16px 18px;
  font-size:15px;font-weight:700;color:var(--ink);transition:.14s;
}
.reason:hover{border-color:var(--teal-border);background:#fbfdfd}
.reason.is-selected{border-color:var(--teal);background:var(--teal-tint)}
.reason__radio{width:18px;height:18px;border-radius:50%;border:2px solid #cfd6dd;flex:0 0 auto;display:grid;place-items:center;transition:.14s}
.reason.is-selected .reason__radio{border-color:var(--teal)}
.reason.is-selected .reason__radio::after{content:"";width:9px;height:9px;border-radius:50%;background:var(--teal)}

/* offer cards */
.offers{display:flex;flex-direction:column;gap:12px;margin-bottom:20px}
.offer{
  display:flex;align-items:flex-start;gap:14px;width:100%;text-align:left;cursor:pointer;
  border:1.6px solid var(--line);background:#fff;border-radius:14px;padding:16px 18px;transition:.15s;
}
.offer:hover{transform:translateY(-1px);box-shadow:var(--shadow-md);border-color:var(--teal-border)}
.offer--primary{border-color:var(--teal-border);background:var(--teal-tint)}
.offer--primary:hover{border-color:var(--teal)}
.offer__badge{width:42px;height:42px;border-radius:11px;background:#fff;color:var(--teal);display:grid;place-items:center;font-size:20px;flex:0 0 auto;border:1px solid var(--teal-border)}
.offer--primary .offer__badge{background:#fff}
.offer__tx{display:flex;flex-direction:column;gap:4px}
.offer__title{font-size:15.5px;font-weight:800;color:var(--ink);line-height:1.3}
.offer__desc{font-size:13.5px;color:var(--ink-2);line-height:1.45}
.offer__best{font-size:11px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;color:var(--teal-700);background:#fff;border:1px solid var(--teal-border);padding:2px 8px;border-radius:20px;margin-left:auto;flex:0 0 auto;align-self:center}

/* buttons inside modal */
.m-actions{display:flex;gap:12px;margin-top:4px}
.btn{flex:1;border:0;border-radius:11px;padding:14px 16px;font-weight:800;font-size:15px;cursor:pointer;transition:.15s;line-height:1.2}
.btn--primary{background:var(--teal);color:#fff;box-shadow:0 6px 16px rgba(0,128,136,.28)}
.btn--primary:hover{background:var(--teal-dark)}
.btn--neutral{background:#f1f3f5;color:var(--ink);border:1px solid var(--line)}
.btn--neutral:hover{background:#e9ecef}
.btn--danger-ghost{background:#fff;color:var(--red);border:1.5px solid #f3c1c4}
.btn--danger-ghost:hover{background:var(--red-soft)}
.btn--full{width:100%;flex:none}

.decline{display:block;width:100%;text-align:center;background:none;border:0;color:var(--ink-2);font-weight:700;font-size:14px;text-decoration:underline;cursor:pointer;padding:8px;margin-top:2px}
.decline:hover{color:var(--ink)}

.export-line{text-align:center;margin-top:14px;font-size:13px;color:var(--ink-3)}
.export-line button{background:none;border:0;color:var(--teal);font-weight:700;text-decoration:underline;cursor:pointer;font-size:13px}

.saved-list{background:var(--teal-tint);border:1px solid var(--teal-border);border-radius:12px;padding:14px 16px;margin:0 0 22px;color:var(--teal-700);font-size:13.5px;font-weight:600;display:flex;align-items:center;gap:10px;line-height:1.45}

/* toast */
.toast{
  position:fixed;left:50%;bottom:28px;transform:translateX(-50%) translateY(20px);
  background:var(--navy);color:#fff;padding:12px 18px;border-radius:12px;font-size:14px;font-weight:600;
  box-shadow:var(--shadow-lg);opacity:0;visibility:hidden;transition:.25s;z-index:200;display:flex;align-items:center;gap:9px;
}
.toast.show{opacity:1;visibility:visible;transform:translateX(-50%) translateY(0)}
.toast svg{color:#5fd0c9}

/* focus visibility */
:focus-visible{outline:2.5px solid var(--teal);outline-offset:2px;border-radius:8px}

/* ---------------------------------- Responsive ---------------------------------- */
@media (max-width:1080px){
  .topbar__links{display:none}
}
@media (max-width:720px){
  :root{--rail:58px}
  .content{padding:18px 14px 50px}
  .page-title{font-size:21px}
  .search{display:none}
  .balance span{display:none}
  .modal{padding:26px 20px 22px;border-radius:18px}
  .m-title{font-size:20px}
  .m-actions{flex-direction:column}
  .plan__right{width:100%}
  .plan__right .btn-outline{flex:1}
}

@media (prefers-reduced-motion: reduce){
  *{transition:none!important;animation:none!important}
}
</style>
</head>
<body>
<div class="app">

  <!-- ============ Slim dark icon rail ============ -->
  <nav class="rail" aria-label="Primary">
    <div class="rail__logo" title="REsimpli">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5 12 3l9 6.5V20a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1z"/></svg>
    </div>
    <button class="rail__btn" title="Leads"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg></button>
    <button class="rail__btn" title="Mail"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg></button>
    <button class="rail__btn" title="AI Writer"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 16 3 21l5-2"/><path d="m3 21 9-9"/><path d="M14 7s1-3 4-3 4 3 4 3-3 1-3 4 3 4 3 4-1 3-4 3-4-3-4-3"/></svg></button>
    <button class="rail__btn" title="Dashboard"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 12 16 8"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg></button>
    <button class="rail__btn" title="Marketing"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg></button>
    <button class="rail__btn" title="Lists"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg></button>
    <button class="rail__btn" title="Properties"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg></button>
    <button class="rail__btn" title="Tasks"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg></button>
    <button class="rail__btn" title="Contacts"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></button>
