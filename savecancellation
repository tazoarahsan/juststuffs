      secondary:{ic:'percent', title:'50% off your next 3 months', desc:'Half off while you get comfortable. Reverts to standard after 3 cycles.', outcome:'disc3'}
    },
    final:{
      primary:{ic:'percent', title:'50% off for your next 6 months', desc:'Six months at half price to make it stick. Reverts to standard after 6 cycles.', outcome:'disc6'},
      secondary:{ic:'pause', title:'Pause your plan — $49/mo', desc:'Keep your numbers active and data safe. Resume anytime.', outcome:'pause'}
    }
  },
  switching:{
    label:'Switching to another product',
    first:{
      primary:{ic:'chat', title:"Talk to our team — tell us what's missing", desc:'A 15-minute call to see if we can close the gap before you go.', outcome:'team'},
      secondary:{ic:'percent', title:'50% off your next 3 months', desc:'Stay at half price while you decide. Reverts to standard after 3 cycles.', outcome:'disc3'}
    },
    final:{
      primary:{ic:'percent', title:'50% off for your next 6 months', desc:'Our best price to keep everything in one place. Reverts after 6 cycles.', outcome:'disc6'},
      secondary:{ic:'pause', title:'Pause your plan — $49/mo', desc:'Keep your numbers active and data safe. Resume anytime.', outcome:'pause'}
    }
  },
  a2p:{
    label:'A2P 10DLC concerns',
    first:{
      primary:{ic:'shield', title:'Guided 10DLC fix + team support', desc:'We walk you through registration and compliance, 1-on-1, until your texting is fully cleared.', outcome:'tendlc'},
      secondary:{ic:'pause', title:'Pause your plan — $49/mo', desc:'Hold your account and numbers while you sort out compliance.', outcome:'pause'}
    },
    final:{ // matrix: A2P final offer = Pause
      primary:{ic:'pause', title:'Pause your plan — $49/mo', desc:'Keep your numbers active and data safe while 10DLC clears. Resume anytime.', outcome:'pause'},
      secondary:{ic:'shield', title:'Guided 10DLC fix + team support', desc:'One more chance to get hands-on help clearing compliance.', outcome:'tendlc'}
    }
  },
  shutdown:{
    label:'Shutting down my business',
    gracefulExit:true, // matrix: "Let them go" — no hard second offer
    first:{
      primary:{ic:'download', title:'Free data export + pause your account', desc:"Download everything and we'll hold your account, in case you're ever back.", outcome:'export'},
      secondary:{ic:'pause', title:'Pause your plan — $49/mo', desc:'Keep your numbers and data parked at a low monthly rate.', outcome:'pause'}
    }
    // no `final` — declining the first offer routes straight to a respectful confirm
  }
};

/* Saved-state copy + how the dashboard plan card should reflect each accepted offer */
const OUTCOMES = {
  disc3:{ msg:"Your 50% discount is locked in for the next 3 months. Same numbers, same automations, same data — nothing else changes.", plan:{name:'REsimpli Pro', pill:['50% off · 3 months','ok'], price:'<s>$399</s> $199.50 / month for 3 months, then $399'} },
  disc6:{ msg:"Your 50% discount is locked in for the next 6 months. Everything stays exactly as it is.", plan:{name:'REsimpli Pro', pill:['50% off · 6 months','ok'], price:'<s>$399</s> $199.50 / month for 6 months, then $399'} },
  basic:{ msg:"You're now on the Basic plan at $199/mo. Your data and numbers carried over — nothing was lost.", plan:{name:'REsimpli Basic', pill:['Active','ok'], price:'$199 / month · renews Jul 17, 2026'} },
  pause:{ msg:"Your plan is paused. Your numbers stay active and your data is safe — resume anytime from this page.", plan:{name:'REsimpli Pro', pill:['Paused','warn'], price:'$49 / month while paused'} },
  concierge:{ msg:"You're booked for a concierge setup call. Our team will reach out within one business day to get everything dialed in — and your subscription stays active.", plan:{name:'REsimpli Pro', pill:['Active · setup call booked','ok'], price:'$399 / month · renews Jul 17, 2026'} },
  team:{ msg:"You're booked. Our team will reach out within one business day to hear what's missing — and your subscription stays active.", plan:{name:'REsimpli Pro', pill:['Active · call booked','ok'], price:'$399 / month · renews Jul 17, 2026'} },
  tendlc:{ msg:"You're booked for a guided 10DLC session. Our team will reach out within one business day to clear your texting compliance — and your subscription stays active.", plan:{name:'REsimpli Pro', pill:['Active · 10DLC help booked','ok'], price:'$399 / month · renews Jul 17, 2026'} },
  export:{ msg:"Your data export is being prepared and your account is paused. We'll email you a download link shortly.", plan:{name:'REsimpli Pro', pill:['Paused · export ready soon','warn'], price:'Paused — export in progress'} }
};

/* ============================================================
   STATE
   ============================================================ */
const state = { step:'lossAversion', reason:null, result:null };
const overlay = document.getElementById('overlay');
const modal   = document.getElementById('modal');
let lastFocus = null;

/* ============================================================
   PROGRESS DOTS
   mode: 'none' | 'mid' (save phase, step 2) | 'confirm' (step 3)
   ============================================================ */
function steps(mode){
  if(mode==='none') return '';
  const mid = mode==='mid';
  return `<div class="steps" aria-hidden="true">
    <span class="node node--done">${'\u2713'}</span>
    <span class="bar bar--done"></span>
    <span class="node ${mid?'node--active':'node--done'}">${mid?'2':'\u2713'}</span>
    <span class="bar ${mid?'':'bar--done'}"></span>
    <span class="node ${mid?'node--todo':'node--active'}">3</span>
  </div>`;
}

function offerCard(o, isPrimary){
  return `<button class="offer ${isPrimary?'offer--primary':''}" data-action="accept" data-outcome="${o.outcome}">
    <span class="offer__badge">${icon(o.ic)}</span>
    <span class="offer__tx">
      <span class="offer__title">${o.title}</span>
      <span class="offer__desc">${o.desc}</span>
    </span>
    ${isPrimary?'<span class="offer__best">Best for you</span>':''}
  </button>`;
}

/* ============================================================
   RENDER each screen
   ============================================================ */
function render(){
  const r = state.reason ? REASONS[state.reason] : null;
  let html = '';

  if(state.step==='lossAversion'){
    html = `
      ${steps('none')}
      <div class="glyph glyph--warn">${icon('warn')}</div>
      <h2 class="m-title" id="mTitle">Are you sure you want to cancel?</h2>
      <p class="m-sub">Cancelling your subscription will have the following effects:</p>
      <div class="effects">
        <div class="effect"><span class="effect__ic">${icon('phone')}</span><span class="effect__tx">All phone numbers will be released permanently</span></div>
        <div class="effect"><span class="effect__ic">${icon('db')}</span><span class="effect__tx">Your data and files will be deleted after 30 days</span></div>
        <div class="effect"><span class="effect__ic">${icon('zap')}</span><span class="effect__tx">You'll lose access to all premium features</span></div>
      </div>
      <div class="m-actions">
        <button class="btn btn--primary" data-action="keep">Keep subscription</button>
        <button class="btn btn--neutral" data-action="goReason">Continue</button>
      </div>`;
  }

  else if(state.step==='reason'){
    const opts = Object.entries(REASONS).map(([id,cfg])=>`
      <button class="reason ${state.reason===id?'is-selected':''}" data-action="pickReason" data-id="${id}" aria-pressed="${state.reason===id}">
        <span class="reason__radio"></span>${cfg.label}
      </button>`).join('');
    html = `
      ${steps('mid')}
      <h2 class="m-title" id="mTitle">What's driving this?</h2>
      <p class="m-sub">This picks the right offer to show you next.</p>
      <div class="reasons">${opts}</div>
      <button class="btn btn--primary btn--full" data-action="goOffer1" ${state.reason?'':'disabled'} style="${state.reason?'':'opacity:.5;cursor:not-allowed;box-shadow:none'}">Continue</button>`;
  }

  else if(state.step==='offer1'){
    html = `
      ${steps('mid')}
      <h2 class="m-title" id="mTitle">Before you go…</h2>
      <p class="m-sub">We'd hate to see you leave. This one's matched to your reason.</p>
      <div class="offers">
        ${offerCard(r.first.primary,true)}
        ${offerCard(r.first.secondary,false)}
      </div>
      <button class="decline" data-action="decline1">No thanks, continue cancelling</button>`;
  }

  else if(state.step==='offer2'){
    html = `
      ${steps('mid')}
      <h2 class="m-title" id="mTitle">One last offer</h2>
      <p class="m-sub">Our best save before you go.</p>
      <div class="offers">
        ${offerCard(r.final.primary,true)}
        ${offerCard(r.final.secondary,false)}
      </div>
      <button class="decline" data-action="decline2">No thanks, continue cancelling</button>`;
  }

  else if(state.step==='confirm'){
    html = `
      ${steps('confirm')}
      <div class="glyph glyph--x">${icon('x')}</div>
      <h2 class="m-title" id="mTitle">Confirm cancellation</h2>
      <p class="m-sub">Numbers released · data deleted in 30 days · access ends today</p>
      <div class="m-actions">
        <button class="btn btn--primary" data-action="keep">Keep subscription</button>
        <button class="btn btn--danger-ghost" data-action="submitCancel">Submit &amp; cancel</button>
      </div>
      <p class="export-line">Want your records first? <button data-action="export">Export my data</button></p>`;
  }

  else if(state.step==='saved'){
    const o = OUTCOMES[state.result?.outcome] || {msg:"You're all set."};
    html = `
      <div class="glyph glyph--ok">${icon('check')}</div>
      <h2 class="m-title" id="mTitle">You're all set</h2>
      <div class="saved-list">${icon('check')}<span>${o.msg}</span></div>
      <button class="btn btn--primary btn--full" data-action="close">Back to billing</button>`;
  }

  else if(state.step==='cancelled'){
    html = `
      <div class="glyph glyph--x">${icon('x')}</div>
      <h2 class="m-title" id="mTitle">Your subscription is cancelled</h2>
      <p class="m-sub">You'll keep access until <strong>Jul 17, 2026</strong>. After that your numbers are released and your data is deleted in 30 days. Sorry to see you go — you're welcome back anytime.</p>
      <button class="btn btn--primary btn--full" data-action="close">Back to billing</button>`;
  }

  modal.innerHTML = html;
  // focus management
  const focusEl = modal.querySelector('.btn--primary, .reason, .offer, button:not([disabled])');
  if(focusEl) focusEl.focus();
}

/* ============================================================
   ACTIONS
   ============================================================ */
modal.addEventListener('click', (e)=>{
  const el = e.target.closest('[data-action]');
  if(!el) return;
  const a = el.dataset.action;

  switch(a){
    case 'keep':
    case 'close':       closeModal(); break;
    case 'goReason':    state.step='reason'; render(); break;
    case 'pickReason':  state.reason = el.dataset.id; render(); break;
    case 'goOffer1':    if(state.reason){ state.step='offer1'; render(); } break;
    case 'decline1':
      // shutdown = graceful exit (no hard final offer)
      state.step = REASONS[state.reason].gracefulExit ? 'confirm' : 'offer2';
      render(); break;
    case 'decline2':    state.step='confirm'; render(); break;
    case 'accept':      acceptOffer(el.dataset.outcome); break;
    case 'submitCancel':state.result={type:'cancelled'}; state.step='cancelled'; render(); break;
    case 'export':      toast('Export started — we\u2019ll email you a download link'); break;
  }
});

function acceptOffer(outcome){
  state.result = {type:'saved', outcome};
  state.step = 'saved';
  render();
}

/* ============================================================
   OPEN / CLOSE + dashboard reflection
   ============================================================ */
function openModal(){
  lastFocus = document.activeElement;
  state.step='lossAversion'; state.reason=null;
  // keep prior result so the plan card persists if reopened, but reset for a fresh run:
  state.result=null;
  render();
  overlay.classList.add('is-open');
  document.body.style.overflow='hidden';
}
function closeModal(){
  overlay.classList.remove('is-open');
  document.body.style.overflow='';
  if(state.result) applyResult(state.result);
  if(lastFocus) lastFocus.focus();
}

document.getElementById('cancelBtn').addEventListener('click', openModal);

// Escape closes (= keep subscription). Backdrop click intentionally does NOT,
// to keep demoers on the designed path.
document.addEventListener('keydown', (e)=>{
  if(e.key==='Escape' && overlay.classList.contains('is-open')) closeModal();
});

/* ---- Plan card rendering ---- */
const DEFAULT_PLAN = {
  name:'REsimpli Pro',
  pill:['Active','ok'],
  price:'$399 / month · renews Jul 17, 2026',
  note:null
};
function planCardHTML(p){
  const [pillText,pillType]=p.pill;
  const cancelled = p.cancelled;
  return `
    <div class="plan__left">
      <div class="plan__name">${p.name} <span class="pill pill--${pillType}">${pillText}</span></div>
      <div class="plan__price">${p.price}</div>
      ${p.note?`<div class="plan__note"><span class="pill pill--ok">${p.note}</span></div>`:''}
      <div class="plan__feats">
        <span class="feat">${icon('check')} All phone numbers</span>
        <span class="feat">${icon('check')} Unlimited automations</span>
        <span class="feat">${icon('check')} AI Co-Pilot</span>
        <span class="feat">${icon('check')} Driving for Dollars</span>
      </div>
    </div>
    <div class="plan__right">
      ${cancelled
        ? `<button class="btn-outline btn-outline--neutral" id="reactivateBtn">Reactivate plan</button>`
        : `<button class="btn-outline btn-outline--neutral">Change plan</button>
           <button class="btn-outline btn-outline--neutral">Manage seats</button>`}
    </div>`;
}
function renderPlan(p){
  document.getElementById('planCard').innerHTML = planCardHTML(p);
  const re = document.getElementById('reactivateBtn');
  if(re) re.addEventListener('click', ()=>{ renderPlan(DEFAULT_PLAN); toast('Welcome back — your plan is active again'); state.result=null; });
}
function applyResult(result){
  if(result.type==='cancelled'){
    renderPlan({name:'REsimpli Pro', pill:['Cancellation scheduled','bad'], price:'Access until Jul 17, 2026 · then numbers released', cancelled:true});
  } else {
    const o = OUTCOMES[result.outcome];
    if(o && o.plan){ renderPlan({...o.plan}); }
  }
}

/* ============================================================
   Toast
   ============================================================ */
let toastTimer;
function toast(msg){
  document.getElementById('toastMsg').textContent = msg;
  const t = document.getElementById('toast');
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'),2600);
}

/* ============================================================
   Live "Gen 2.0 expires" countdown (cosmetic, matches banner)
   ============================================================ */
(function(){
  const el=document.getElementById('genCountdown');
  const target = Date.now() + (27*86400 + 8*3600 + 1*60 + 1)*1000;
  function tick(){
    let s=Math.max(0,Math.floor((target-Date.now())/1000));
    const d=Math.floor(s/86400); s-=d*86400;
    const h=Math.floor(s/3600);  s-=h*3600;
    const m=Math.floor(s/60);    s-=m*60;
    const p=n=>String(n).padStart(2,'0');
    el.textContent=`Gen 2.0 AI features expire in ${d}D: ${p(h)}H:${p(m)}M: ${p(s)}S`;
  }
  tick(); setInterval(tick,1000);
})();

/* init */
renderPlan(DEFAULT_PLAN);
</script>
